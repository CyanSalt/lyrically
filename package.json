{
  "name": "lyrically",
  "version": "0.7.0",
  "productName": "Lyrically",
  "description": "Music player inspired by Lyric Speaker",
  "main": "dist/main/index.js",
  "scripts": {
    "postinstall": "electron-rebuild",
    "dev": "node build/build.mjs && electron .",
    "build": "node build/build.mjs && node build/pack.mjs -- --local",
    "pack": "node build/build.mjs && node build/pack.mjs",
    "release": "release-it",
    "lint:script": "eslint --cache --fix './**/*.{cjs,js,mjs,ts,vue}'",
    "lint:style": "stylelint --ignore-path .gitignore --cache --fix ./**/*.{css,scss,vue}",
    "lint": "pnpm run lint:script && pnpm run lint:style"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CyanSalt/lyrically.git"
  },
  "author": "CyanSalt",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/CyanSalt/lyrically/issues"
  },
  "homepage": "https://github.com/CyanSalt/lyrically#readme",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.15.0",
      "onFail": "error"
    },
    "packageManager": [
      {
        "name": "pnpm",
        "version": "^11.0.0",
        "onFail": "error"
      },
      {
        "name": "npm",
        "onFail": "ignore"
      }
    ]
  },
  "devDependencies": {
    "@cyansalt/eslint-config": "^4.4.2",
    "@cyansalt/stylelint-config": "^4.2.0",
    "@cyansalt/tsconfig": "^3.0.0",
    "@electron/packager": "^20.0.0",
    "@electron/rebuild": "^4.0.1",
    "@lucide/vue": "^1.14.0",
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/lodash": "^4.17.20",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.12.3",
    "@types/seedrandom": "^3.0.8",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vueuse/core": "^14.3.0",
    "color.js": "^1.2.0",
    "colord": "^2.9.3",
    "dotenv": "^17.2.2",
    "electron": "^38.1.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "figma-squircle": "^1.1.0",
    "lodash-es": "^4.17.21",
    "mri": "^1.2.0",
    "picocolors": "^1.1.1",
    "png2icons": "^2.0.1",
    "release-it": "^20.0.1",
    "sass": "^1.92.1",
    "seedrandom": "^3.0.5",
    "segmentit": "^2.0.3",
    "simple-icons": "^16.18.1",
    "stylelint": "^17.11.0",
    "typescript": "^5.9.2",
    "vite": "^8.0.11"
  },
  "dependencies": {
    "@vue/reactivity": "^3.5.21",
    "applescript": "^1.0.0",
    "node-mac-notch": "github:codebytere/node-mac-notch",
    "semver": "^7.7.2",
    "vue": "^3.5.21"
  }
}
